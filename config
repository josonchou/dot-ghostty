# Config generated by Ghostty Config

# initial-command= "/bin/zsh -c 'tmux new-session -A -s workspace'"
shell-integration = zsh
shell-integration-features = true
# window-save-state = always
  
# theme = GitHub DarkS
# theme=CyberpunkScarletProtocol
# theme=xcodedark
theme = Github Dark High Contrast
# initial-window=false

font-family = Hack Nerd Font Mono
# font-family = GoogleSansCode Nerd Font
# font-family = PingFang SC

font-style = 500      # 常规字重（通常为400）
font-style-bold = "Bold"    # 粗体字重（通常为700）

font-size = 18.0

macos-titlebar-style = tabs

background-opacity = 0.9
background-blur-radius = 18
unfocused-split-opacity = 0.7
clipboard-read = allow
clipboard-write = allow
cursor-click-to-move = true
window-vsync = true

cursor-style = block
cursor-style-blink = false
cursor-color = #47a0d2
cursor-invert-fg-bg = true
# cursor-opacity = 0.6

auto-update = check


# custom-shader = shaders/animated-gradient-shader.glsl
custom-shader = shaders/cursor_frozen.glsl
custom-shader-animation = always
#
macos-option-as-alt = true

maximize = true


shell-integration-features = no-cursor

# quick terminal
quick-terminal-position = "top"
# quick-terminal-size = "90%"
quick-terminal-autohide = false
quick-terminal-screen = "macos-menu-bar"
quick-terminal-space-behavior = move

keybind = global:alt+shift+space=toggle_quick_terminal
# keybind = chain=text:export GHOSTTY_QUICK=1\n
# keybind = chain=text:tmux new-session -A -s quick_terminal\n

# 窗口内边距
window-padding-x = 4
window-padding-y = 4
# 自动平衡剩余空间使内容居中
window-padding-balance = true
# 确保边距背景色延伸
window-padding-color = extend
# keybind = shift+enter=text:\x1b\r
